<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.arkaitz.bot</string>

    <key>ProgramArguments</key>
    <array>
        <string>/usr/bin/python3</string>
        <string>/Users/mac/Desktop/Arkaitz/telegram_bot/bot.py</string>
    </array>

    <key>WorkingDirectory</key>
    <string>/Users/mac/Desktop/Arkaitz/telegram_bot</string>

    <!-- Arrancar al iniciar sesión y mantener vivo si crashea -->
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>

    <!-- Si crashea, esperar 30s antes de reintentar (evita bucles rápidos) -->
    <key>ThrottleInterval</key>
    <integer>30</integer>

    <!-- Logs -->
    <key>StandardOutPath</key>
    <string>/Users/mac/Desktop/Arkaitz/logs/bot.out.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/mac/Desktop/Arkaitz/logs/bot.err.log</string>

    <!-- PATH para que encuentre binarios de Homebrew (ffmpeg, etc.) -->
    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
    </dict>
</dict>
</plist>
