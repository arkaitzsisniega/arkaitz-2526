# ─────────────────────────────────────────────────────────────────────
# Bot de DATOS (@InterFS_datos_bot)
# ─────────────────────────────────────────────────────────────────────

# 1) Token del bot (pide a @BotFather en Telegram tras crear el bot)
TELEGRAM_BOT_TOKEN=

# 2) Lista de chat_ids AUTORIZADOS (separados por comas).
#    Cada persona debe escribir a @userinfobot para saber su chat_id.
#    Ejemplo con 3 usuarios:
#    ALLOWED_CHAT_IDS=6357476517, 123456789, 987654321
ALLOWED_CHAT_IDS=

